  "privacy_title": "Privacy & data",
  "privacy_intro": "AirWatch is a public flight-tracking app with no user accounts. We don't set tracking cookies, don't run third-party analytics, and don't sell or share data. The page below lists everything that is persisted, where, and for how long.",
  "privacy_local_storage_title": "Stored in your browser (localStorage)",
  "privacy_local_storage_intro": "These are visible to the AirWatch site only. They never leave your device unless you explicitly sync (no sync exists today).",
  "privacy_col_key": "Key",
  "privacy_col_purpose": "Purpose",
  "privacy_col_lifetime": "Lifetime",
  "privacy_clientid_purpose": "Random per-browser id used by Push + GeoFence delivery.",
  "privacy_favorites_purpose": "Your starred flights / airports / airlines.",
  "privacy_stats_purpose": "Personal flight-view counter (capped at 500 entries).",
  "privacy_settings_purpose": "Theme, language, units, map style, refresh interval.",
  "privacy_geofences_purpose": "Geo-fence alert history (deduped, capped).",
  "privacy_lifetime_until_clear": "Until you clear it",
  "privacy_local_storage_clear_hint": "Settings → Stats → Clear data wipes everything above. The browser's site-data clear works too.",
  "privacy_server_title": "Stored on the AirWatch server",
  "privacy_server_ip_hash": "Your IP address is hashed with a daily-rotating salt before any stat is written. The raw IP never lands in the analytics tables.",
  "privacy_server_geoip": "When GeoIP is enabled, your IP is resolved to a country code (no city, no ISP, no precise location).",
  "privacy_server_view_beacons": "Anonymous view counters per route (e.g. \"the airports page was opened N times today\"). No per-user history.",
  "privacy_server_no_account": "No accounts, no profiles, no email, no name.",
  "privacy_third_party_title": "Third-party services we proxy",
  "privacy_third_party_intro": "Map tiles + flight data + photos load via these upstreams. The AirWatch backend acts as a proxy so your IP stays hidden from them — except for direct-CDN map tiles, which load straight from the tile provider.",
  "privacy_third_airlabs": "Live flight positions + airport metadata.",
  "privacy_third_weather": "Weather conditions on airport pages.",
  "privacy_third_hexdb": "Aircraft registry lookup by hex code.",
  "privacy_third_photos": "Aircraft photographs.",
  "privacy_third_tiles": "Background map tiles (loaded directly by your browser; the tile provider sees your IP).",
  "privacy_third_radar": "Weather-radar overlay tiles.",
  "privacy_rights_title": "Your rights (EU / EEA / UK)",
