# Copy to .env.local and adjust. NEVER commit .env.local.

# Backend URL — the Next.js rewrite forwards /api/proxy/* to this target.
# Leave as localhost for dev; point at your deployed airwatch-api in production.
NEXT_PUBLIC_PROXY_URL=http://localhost:8080

# Optional: set to your LAN IP to access the dev server from your phone.
# Example: HOSTNAME=192.168.178.31
