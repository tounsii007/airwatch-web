{
  "name": "airwatch-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:local": "next dev",
    "dev:https": "next dev --experimental-https --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "size": "size-limit",
    "generate:api-types": "openapi-typescript http://localhost:8080/v3/api-docs --output src/lib/api-types.generated.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "size-limit": [
    {
      "name": "All JS chunks (raw)",
      "path": ".next/static/chunks/*.js",
      "limit": "2500 KB",
      "brotli": false,
      "gzip": false
    },
    {
      "name": "All CSS (raw)",
      "path": ".next/static/chunks/*.css",
      "limit": "150 KB",
      "brotli": false,
      "gzip": false
    }
  ],
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "cesium": "^1.140.0",
    "deck.gl": "^9.3.1",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^1.8.0",
    "maplibre-gl": "^4.7.1",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "resium": "^1.20.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "openapi-typescript": "^7.13.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  }
}
